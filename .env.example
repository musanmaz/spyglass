# ─────────────────────────────────────────────────────────────────────────────
# Spyglass — Environment Variables
# ─────────────────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in the values:
#   cp .env.example .env
# ─────────────────────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────────────────────
ENVIRONMENT=production
APP_NAME=Spyglass
ORG_NAME=Your Organization
PRIMARY_ASN=65000
WEBSITE_URL=https://www.example.com
PEERINGDB_URL=https://www.peeringdb.com/asn/65000
SERVER_NAME=lg.example.com

# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me-generate-a-random-secret

# Enable Swagger/ReDoc at /api/docs and /api/redoc (disable in production)
ENABLE_DOCS=false

# ── Security ─────────────────────────────────────────────────────────────────
# Shared token between Nginx proxy and backend (used when REQUIRE_API_TOKEN=true)
API_PROXY_TOKEN=change-me-to-a-random-token

# Set to false if frontend and backend are on different domains (e.g. Vercel + VPS)
REQUIRE_API_TOKEN=true

# CORS — JSON array of allowed frontend origins
CORS_ORIGINS=["https://lg.example.com"]
ALLOWED_ORIGINS=["https://lg.example.com"]

# ── Database ─────────────────────────────────────────────────────────────────
DB_PASSWORD=change-me-strong-password
POSTGRES_USER=spyglass
DATABASE_URL=postgresql+asyncpg://spyglass:${DB_PASSWORD}@db:5432/spyglass

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=change-me-strong-password
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0

# ── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_QUERY=20
RATE_LIMIT_QUERY_WINDOW=60
RATE_LIMIT_GENERAL=60
RATE_LIMIT_GENERAL_WINDOW=60

# ── Device Defaults ──────────────────────────────────────────────────────────
# Global SSH credentials (overrides per-device values in devices.yaml)
# Leave empty to use per-device credentials from devices.yaml
DEVICE_SSH_USERNAME=
DEVICE_SSH_PASSWORD=

# SSH connection / command timeout (seconds)
SSH_TIMEOUT=10
SSH_COMMAND_TIMEOUT=30

# ── Cache ────────────────────────────────────────────────────────────────────
CACHE_TTL=120

# ── Frontend (Vite) ──────────────────────────────────────────────────────────
# Only needed if frontend is hosted separately from backend (e.g. Vercel)
# VITE_WS_URL=wss://api.lg.example.com/ws/query
# VITE_APP_NAME=Spyglass
# VITE_ORG_NAME=Your Organization
# VITE_ASN=65000
