# Spyglass — Environment Variables

# Application
ENVIRONMENT=production
APP_NAME=Spyglass
ORG_NAME=Your Organization
PRIMARY_ASN=65000
WEBSITE_URL=https://www.example.com
PEERINGDB_URL=https://www.peeringdb.com/asn/65000
SERVER_NAME=lg.example.com
SECRET_KEY=change-me-generate-with-scripts/generate_secret.py
ENABLE_DOCS=false

# Database
DB_PASSWORD=change-me-strong-password
DATABASE_URL=postgresql+asyncpg://spyglass:${DB_PASSWORD}@db:5432/spyglass

# Redis
REDIS_PASSWORD=change-me-strong-password
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0

# CORS
CORS_ORIGINS=["https://lg.example.com"]

# Rate Limiting
RATE_LIMIT_QUERY=20
RATE_LIMIT_QUERY_WINDOW=60
RATE_LIMIT_GENERAL=60
RATE_LIMIT_GENERAL_WINDOW=60

# SSH Defaults
SSH_TIMEOUT=10
SSH_COMMAND_TIMEOUT=30

# Cache
CACHE_TTL=120
